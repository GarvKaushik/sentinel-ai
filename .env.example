# Copy to .env and fill in. .env is git-ignored; never commit real keys.

# --- Required for `docker compose up` ---
# Groq API key (the LLM agents).
GROQ_API_KEY=your-groq-key-here
# Jina API key (the hosted embedder the deploy image uses).
JINA_API_KEY=your-jina-key-here
# Postgres password. Pick a strong, URL-safe value (letters/digits) — it goes
# into the DATABASE_URL connection string. NOTE: Postgres only applies this on
# first init, so changing it after the DB volume exists needs
# `docker compose down -v` first.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Embeddings backend ---
# "jina" (compose default): hosted embeddings, light image, needs JINA_API_KEY.
# "local": all-MiniLM-L6-v2 — offline, no key, but pulls torch (heavy).
# Ingest and query must use the SAME backend.
#EMBEDDING_BACKEND=jina
JINA_MODEL=jina-embeddings-v3
JINA_DIM=1024

# --- Bare local run only (compose sets these for you) ---
# Only needed if you run the app outside compose and want persistence + async.
# QDRANT_URL defaults to localhost if unset.
#QDRANT_URL=http://localhost:6333
#DATABASE_URL=postgresql+psycopg://sentinel:your-password@localhost:5432/sentinel
#CELERY_BROKER_URL=redis://localhost:6379/0
#CELERY_RESULT_BACKEND=redis://localhost:6379/1
