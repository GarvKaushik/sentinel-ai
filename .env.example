# Copy to .env and fill in. .env is git-ignored; never commit real keys.

# Required: Groq API key (OpenAI-compatible endpoint) for the LLM agents.
GROQ_API_KEY=your-groq-key-here

# Qdrant location. Defaults to the local docker-compose port if unset.
# Inside the app container (docker compose), this is set to the service URL.
QDRANT_URL=http://localhost:6333

# --- Optional: persistence + async queue ---
# docker-compose sets these to the postgres/redis services automatically, so you
# don't need them for `docker compose up`. Set them only for a bare local run if
# you want investigation history (DATABASE_URL) and async /alert (CELERY_*).
# Leaving them unset disables persistence and makes /alert run synchronously.
# DATABASE_URL=postgresql+psycopg://sentinel:sentinel_dev_pw@localhost:5432/sentinel
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
